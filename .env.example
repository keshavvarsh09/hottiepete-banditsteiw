# ┌─────────────────────────────────────────────────────────────┐
# │  hottiepete banditsteiw — Environment Variables            │
# │  Copy this file to .env and fill in your keys.             │
# └─────────────────────────────────────────────────────────────┘

# ── Fish Audio TTS ──────────────────────────────────────────
# Sign up at https://fish.audio and create an API key.
# Voice IDs: go to fish.audio, find or clone a voice, copy its ID.
FISH_API_KEY=
FISH_VOICE_A=
FISH_VOICE_B=

# ── Groq (free LLM for script generation) ──────────────────
# Get a free key at https://console.groq.com
# The script generator uses this to write two-character dialogue.
# If left blank, a basic placeholder script is used instead (no crash).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Frontend → Backend connection ──────────────────────────
# For local dev, leave as-is. For production, set to your
# deployed backend URL (e.g. https://your-app.up.railway.app).
BACKEND_BASE_URL=http://localhost:8000

# ── Storage paths (relative to backend root) ───────────────
# These directories are auto-created on startup.
DATABASE_URL=sqlite:///./data/app.db
ASSETS_DIR=./assets
RENDERS_DIR=./renders
